<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Isolates this OSS dev-tooling project from any machine-wide/corporate
       NuGet feeds configured elsewhere (e.g. a private Azure DevOps feed
       that 401s without credentials this project has no business having) —
       it only ever needs the public Sentry package from nuget.org. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
